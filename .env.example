# ── Wallet / RPC ─────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=
RPC_URL=
HELIUS_API_KEY=

# ── Telegram Notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_STARTUP=true
TELEGRAM_NOTIFY_HOLD=false
TELEGRAM_NOTIFY_ERRORS=true
TELEGRAM_TIMEOUT_MS=15000
TELEGRAM_RETRY_COUNT=1

# ── Runtime ──────────────────────────────────────────────────────────────────
DRY_RUN=true
LOG_LEVEL=info
TIMEZONE=Asia/Jakarta
POLL_INTERVAL_MINUTES=5

# ── Exit Strategy Defaults ───────────────────────────────────────────────────
TIMEFRAME=1H
CANDLE_SOURCE=meteora
# Supported:
# - meteora => 5m, 30m, 1h, 2h, 4h, 12h, 24h
# - birdeye => 1m, 3m, 5m, 15m, 30m, 1h, 2h, 4h, 6h, 8h, 12h, 24h
BB_TOUCH_RULE=high_gte_upper_band
MACD_GREEN_RULE=first_histogram_red_to_green
EXIT_CLOSE_FULL=true
EXIT_SWAP_TO_SOL=true

# ── Indicator Settings ───────────────────────────────────────────────────────
BB_PERIOD=20
BB_STDDEV=2
RSI_PERIOD=2
RSI_EXIT_THRESHOLD=90
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# ── Swap Adapter ─────────────────────────────────────────────────────────────
# Used only when CANDLE_SOURCE=birdeye
BIRDEYE_API_KEY=

# Optional. Used only for post-close swap to SOL via Jupiter.
JUPITER_API_KEY=
