# ── Wallet / RPC ─────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=
RPC_URL=
HELIUS_API_KEY=

# ── Telegram Notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_STARTUP=true
TELEGRAM_NOTIFY_HOLD=false
TELEGRAM_NOTIFY_ERRORS=true

# ── Runtime ──────────────────────────────────────────────────────────────────
DRY_RUN=true
LOG_LEVEL=info
POLL_INTERVAL_MINUTES=5

# ── Exit Strategy Defaults ───────────────────────────────────────────────────
TIMEFRAME=1H
CANDLE_SOURCE=meteora
BB_TOUCH_RULE=high_gte_upper_band
MACD_GREEN_RULE=first_histogram_red_to_green
EXIT_CLOSE_FULL=true
EXIT_SWAP_TO_SOL=true

# ── Indicator Settings ───────────────────────────────────────────────────────
BB_PERIOD=20
BB_STDDEV=2
RSI_PERIOD=2
RSI_EXIT_THRESHOLD=90
MACD_FAST=12
MACD_SLOW=26
MACD_SIGNAL=9

# ── Swap Adapter ─────────────────────────────────────────────────────────────
# Optional. Used only for post-close swap to SOL via Jupiter.
JUPITER_API_KEY=
